{
  "openapi": "3.1.0",
  "info": { "title": "SoloCooking API", "version": "v1" },
  "servers": [
    { "url": "/api", "description": "Base API path for SoloCooking app" }
  ],
  "tags": [
    {
      "name": "ingredient-controller",
      "description": "Endpoints for ingredient catalog management."
    },
    {
      "name": "recipe-controller",
      "description": "Endpoints for recipe management."
    }
  ],
  "paths": {
    "/recipes/{recipeId}": {
      "get": {
        "tags": ["recipe-controller"],
        "summary": "Get recipe by id",
        "description": "Returns a recipe for given id",
        "operationId": "getRecipe",
        "parameters": [
          {
            "name": "recipeId",
            "in": "path",
            "required": true,
            "schema": { "type": "string", "format": "uuid" }
          }
        ],
        "responses": {
          "200": {
            "description": "Recipe returned",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/RecipeDTO" }
              }
            }
          },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      },
      "put": {
        "tags": ["recipe-controller"],
        "summary": "Updates entire recipe",
        "operationId": "updateRecipe",
        "parameters": [
          {
            "name": "recipeId",
            "in": "path",
            "required": true,
            "schema": { "type": "string", "format": "uuid" }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/UpdateRecipeRequest" }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Recipe updated",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/RecipeDTO" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      },
      "delete": {
        "tags": ["recipe-controller"],
        "summary": "Delete recipe by id",
        "description": "Deletes the recipe when it exists. Repeated requests return no content.",
        "operationId": "deleteRecipe",
        "parameters": [
          {
            "name": "recipeId",
            "in": "path",
            "required": true,
            "schema": { "type": "string", "format": "uuid" }
          }
        ],
        "responses": {
          "204": { "description": "Recipe deleted or already absent" }
        }
      }
    },
    "/recipes": {
      "get": {
        "tags": ["recipe-controller"],
        "summary": "Get all recipes",
        "description": "Returns a paginated list of all available recipes",
        "operationId": "getRecipes",
        "parameters": [
          {
            "name": "page",
            "in": "query",
            "description": "Zero-based page index (0..N)",
            "required": false,
            "schema": { "type": "integer", "default": 0, "minimum": 0 }
          },
          {
            "name": "size",
            "in": "query",
            "description": "The size of the page to be returned",
            "required": false,
            "schema": { "type": "integer", "default": 20, "minimum": 1 }
          },
          {
            "name": "sort",
            "in": "query",
            "description": "Sorting criteria in the format: property,(asc|desc). Default sort order is ascending. Multiple sort criteria are supported.",
            "required": false,
            "schema": { "type": "array", "items": { "type": "string" } }
          }
        ],
        "responses": {
          "200": {
            "description": "Recipes returned",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PageResponseRecipeSummaryDTO"
                }
              }
            }
          }
        }
      },
      "post": {
        "tags": ["recipe-controller"],
        "summary": "Creates new recipe",
        "operationId": "createRecipe",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/CreateRecipeRequest" }
            }
          },
          "required": true
        },
        "responses": {
          "201": {
            "description": "Recipe created",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/RecipeDTO" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      }
    },
    "/ingredients": {
      "get": {
        "tags": ["ingredient-controller"],
        "summary": "Get all ingredients",
        "operationId": "getIngredients",
        "parameters": [
          {
            "name": "page",
            "in": "query",
            "description": "Zero-based page index (0..N)",
            "required": false,
            "schema": { "type": "integer", "default": 0, "minimum": 0 }
          },
          {
            "name": "size",
            "in": "query",
            "description": "The size of the page to be returned",
            "required": false,
            "schema": { "type": "integer", "default": 20, "minimum": 1 }
          },
          {
            "name": "sort",
            "in": "query",
            "description": "Sorting criteria in the format: property,(asc|desc). Default sort order is ascending. Multiple sort criteria are supported.",
            "required": false,
            "schema": { "type": "array", "items": { "type": "string" } }
          }
        ],
        "responses": {
          "200": {
            "description": "Ingredients returned",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PageResponseIngredientDTO"
                }
              }
            }
          }
        }
      },
      "post": {
        "tags": ["ingredient-controller"],
        "summary": "Creates new ingredient",
        "operationId": "createIngredient",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateIngredientRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "201": {
            "description": "Ingredient created",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/IngredientDTO" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "409": { "$ref": "#/components/responses/Conflict" }
        }
      }
    },
    "/ingredients/{ingredientId}": {
      "get": {
        "tags": ["ingredient-controller"],
        "summary": "Get ingredient by id",
        "operationId": "getIngredient",
        "parameters": [
          {
            "name": "ingredientId",
            "in": "path",
            "required": true,
            "schema": { "type": "string", "format": "uuid" }
          }
        ],
        "responses": {
          "200": {
            "description": "Ingredient returned",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/IngredientDTO" }
              }
            }
          },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      },
      "delete": {
        "tags": ["ingredient-controller"],
        "summary": "Deletes ingredient",
        "description": "Deletes an unused ingredient. Repeated requests return no content.",
        "operationId": "deleteIngredient",
        "parameters": [
          {
            "name": "ingredientId",
            "in": "path",
            "required": true,
            "schema": { "type": "string", "format": "uuid" }
          }
        ],
        "responses": {
          "204": { "description": "Ingredient deleted or already absent" },
          "409": { "$ref": "#/components/responses/Conflict" }
        }
      },
      "patch": {
        "tags": ["ingredient-controller"],
        "summary": "Updates ingredient",
        "operationId": "updateIngredient",
        "parameters": [
          {
            "name": "ingredientId",
            "in": "path",
            "required": true,
            "schema": { "type": "string", "format": "uuid" }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateIngredientRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Ingredient updated",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/IngredientDTO" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "404": { "$ref": "#/components/responses/NotFound" },
          "409": { "$ref": "#/components/responses/Conflict" }
        }
      }
    },
    "/ingredients/search": {
      "get": {
        "tags": ["ingredient-controller"],
        "summary": "Search ingredients",
        "operationId": "searchIngredients",
        "parameters": [
          {
            "name": "name",
            "in": "query",
            "description": "Case-insensitive name fragment",
            "required": true,
            "schema": { "type": "string", "maxLength": 255, "minLength": 1 }
          },
          {
            "name": "page",
            "in": "query",
            "description": "Zero-based page index (0..N)",
            "required": false,
            "schema": { "type": "integer", "default": 0, "minimum": 0 }
          },
          {
            "name": "size",
            "in": "query",
            "description": "The size of the page to be returned",
            "required": false,
            "schema": { "type": "integer", "default": 20, "minimum": 1 }
          },
          {
            "name": "sort",
            "in": "query",
            "description": "Sorting criteria in the format: property,(asc|desc). Default sort order is ascending. Multiple sort criteria are supported.",
            "required": false,
            "schema": { "type": "array", "items": { "type": "string" } }
          }
        ],
        "responses": {
          "200": {
            "description": "Matching ingredients returned",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PageResponseIngredientDTO"
                }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "ProblemDetail": {
        "properties": {
          "type": { "type": "string", "format": "uri" },
          "title": { "type": "string" },
          "status": { "type": "integer", "format": "int32" },
          "detail": { "type": "string" },
          "instance": { "type": "string", "format": "uri" },
          "properties": {
            "type": "object",
            "additionalProperties": { "type": "object" }
          }
        }
      },
      "BadRequestProblemDetail": {
        "properties": {
          "type": { "type": "string", "format": "uri" },
          "title": { "type": "string" },
          "status": { "type": "integer", "format": "int32" },
          "detail": { "type": "string" },
          "instance": { "type": "string", "format": "uri" },
          "properties": {
            "type": "object",
            "additionalProperties": { "type": "object" }
          },
          "errors": {
            "type": "object",
            "additionalProperties": {
              "type": "string",
              "description": "Validation messages keyed by request field"
            },
            "description": "Validation messages keyed by request field"
          }
        }
      },
      "UpdateRecipeIngredientRequest": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "ingredientId": { "type": "string", "format": "uuid" },
          "amount": { "type": "number" },
          "unit": { "type": "string", "maxLength": 64, "minLength": 0 },
          "note": { "type": "string", "maxLength": 500, "minLength": 0 }
        },
        "required": ["amount", "ingredientId", "unit"]
      },
      "UpdateRecipeRequest": {
        "type": "object",
        "properties": {
          "name": { "type": "string", "maxLength": 255, "minLength": 0 },
          "imageUrl": {
            "type": "string",
            "maxLength": 2048,
            "minLength": 0,
            "pattern": "^(https?://).*$"
          },
          "description": {
            "type": "string",
            "maxLength": 5000,
            "minLength": 0
          },
          "sections": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/UpdateRecipeSectionRequest"
            },
            "minItems": 1
          }
        },
        "required": ["description", "imageUrl", "name", "sections"]
      },
      "UpdateRecipeSectionRequest": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "name": { "type": "string", "maxLength": 255, "minLength": 0 },
          "ingredients": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/UpdateRecipeIngredientRequest"
            },
            "minItems": 1
          }
        },
        "required": ["ingredients", "name"]
      },
      "RecipeDTO": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "name": { "type": "string" },
          "imageUrl": { "type": "string" },
          "description": { "type": "string" },
          "sections": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/RecipeSectionDTO" }
          },
          "updatedAt": { "type": "string", "format": "date-time" },
          "createdAt": { "type": "string", "format": "date-time" }
        },
        "required": [
          "createdAt",
          "description",
          "id",
          "imageUrl",
          "name",
          "sections",
          "updatedAt"
        ]
      },
      "RecipeIngredientDTO": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "ingredientId": { "type": "string", "format": "uuid" },
          "amount": { "type": "number" },
          "unit": { "type": "string" },
          "note": { "type": ["string", "null"] },
          "position": { "type": "integer", "format": "int32" }
        },
        "required": ["amount", "id", "ingredientId", "note", "position", "unit"]
      },
      "RecipeSectionDTO": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "name": { "type": "string" },
          "position": { "type": "integer", "format": "int32" },
          "ingredients": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/RecipeIngredientDTO" }
          }
        },
        "required": ["id", "ingredients", "name", "position"]
      },
      "CreateRecipeIngredientRequest": {
        "type": "object",
        "properties": {
          "ingredientId": { "type": "string", "format": "uuid" },
          "amount": { "type": "number" },
          "unit": { "type": "string", "maxLength": 64, "minLength": 0 },
          "note": { "type": "string", "maxLength": 500, "minLength": 0 }
        },
        "required": ["amount", "ingredientId", "unit"]
      },
      "CreateRecipeRequest": {
        "type": "object",
        "properties": {
          "name": { "type": "string", "maxLength": 255, "minLength": 0 },
          "imageUrl": {
            "type": "string",
            "maxLength": 2048,
            "minLength": 0,
            "pattern": "^(https?://).*$"
          },
          "description": {
            "type": "string",
            "maxLength": 5000,
            "minLength": 0
          },
          "sections": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/CreateRecipeSectionRequest"
            },
            "minItems": 1
          }
        },
        "required": ["description", "imageUrl", "name", "sections"]
      },
      "CreateRecipeSectionRequest": {
        "type": "object",
        "properties": {
          "name": { "type": "string", "maxLength": 255, "minLength": 0 },
          "ingredients": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/CreateRecipeIngredientRequest"
            },
            "minItems": 1
          }
        },
        "required": ["ingredients", "name"]
      },
      "CreateIngredientRequest": {
        "type": "object",
        "properties": {
          "name": { "type": "string", "maxLength": 255, "minLength": 1 }
        },
        "required": ["name"]
      },
      "IngredientDTO": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "name": { "type": "string" }
        },
        "required": ["id", "name"]
      },
      "UpdateIngredientRequest": {
        "type": "object",
        "properties": {
          "name": {
            "type": ["string", "null"],
            "maxLength": 255,
            "minLength": 1,
            "pattern": "(?s).*\\S.*"
          }
        }
      },
      "PageMetadata": {
        "type": "object",
        "properties": {
          "number": { "type": "integer", "format": "int32" },
          "size": { "type": "integer", "format": "int32" },
          "totalElements": { "type": "integer", "format": "int64" },
          "totalPages": { "type": "integer", "format": "int32" }
        },
        "required": ["number", "size", "totalElements", "totalPages"]
      },
      "PageResponseRecipeSummaryDTO": {
        "type": "object",
        "properties": {
          "content": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/RecipeSummaryDTO" }
          },
          "page": { "$ref": "#/components/schemas/PageMetadata" }
        },
        "required": ["content", "page"]
      },
      "RecipeSummaryDTO": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "name": { "type": "string" },
          "imageUrl": { "type": "string" },
          "description": { "type": "string" },
          "updatedAt": { "type": "string", "format": "date-time" },
          "createdAt": { "type": "string", "format": "date-time" }
        },
        "required": [
          "createdAt",
          "description",
          "id",
          "imageUrl",
          "name",
          "updatedAt"
        ]
      },
      "PageResponseIngredientDTO": {
        "type": "object",
        "properties": {
          "content": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/IngredientDTO" }
          },
          "page": { "$ref": "#/components/schemas/PageMetadata" }
        },
        "required": ["content", "page"]
      }
    },
    "responses": {
      "BadRequest": {
        "description": "Request validation failed",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/BadRequestProblemDetail" }
          }
        }
      },
      "NotFound": {
        "description": "Requested resource was not found",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/ProblemDetail" }
          }
        }
      },
      "Conflict": {
        "description": "Request conflicts with current resource state",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/ProblemDetail" }
          }
        }
      }
    }
  }
}
